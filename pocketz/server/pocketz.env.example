# Pocketz Server Configuration
# Copy this file to /etc/pocketz/pocketz.env and customize for your system

# Server Settings
NODE_ENV=production
POCKETZ_PORT=6767
POCKETZ_API_KEY=pocketz-api-key-2024

# Path Configuration
# IMPORTANT: Update these paths to match your system
POCKETZ_DOWNLOADS_DIR=$HOME/Downloads
POCKETZ_VAULT_DIR=$HOME/data/vaults/pocketz
POCKETZ_PAPERS_DIR=$HOME/data/vaults/pocketz/papers
POCKETZ_INDEX_FILE=$HOME/data/vaults/pocketz/index.md

# Optional: Logging (systemd handles this by default)
# POCKETZ_LOG_DIR=/var/log/pocketz
