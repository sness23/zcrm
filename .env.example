# Discord Integration
# Get your webhook URL from Discord:
# 1. Go to your Discord server
# 2. Right-click on #general channel
# 3. Select "Edit Channel" → "Integrations" → "Webhooks"
# 4. Click "New Webhook" or copy existing webhook URL
# 5. Copy the webhook URL and paste it below
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Discord Bot Configuration (for bidirectional sync)
# To enable messages FROM Discord TO comms-app:
# 1. Go to Discord Developer Portal: https://discord.com/developers/applications
# 2. Create a new application (or use existing)
# 3. Go to "Bot" section and create a bot
# 4. Copy the bot token and paste below
# 5. Enable these intents: Server Members Intent, Message Content Intent
# 6. Go to your Discord server, right-click on #general channel
# 7. Copy channel ID (enable Developer Mode in Discord settings first)
# 8. Invite bot to your server with these permissions: Read Messages, Send Messages
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# Other environment variables...
