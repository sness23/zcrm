# Pocketz Worker Configuration

# WebSocket URL for EC2 server
# Default: ws://localhost:9500
EC2_WEBSOCKET_URL=ws://your-ec2-ip:9500

# Authentication token (MUST match server-side POCKETZ_WORKER_TOKEN)
# Generate a secure token: openssl rand -hex 32
POCKETZ_WORKER_TOKEN=your-secret-token-here

# Chrome CDP URL (for connecting to existing Chrome instance)
# Start Chrome with: google-chrome --remote-debugging-port=9222 --user-data-dir=/path/to/profile
# Default: http://localhost:9222
CHROME_CDP_URL=http://localhost:9222

# Local Pocketz server URL
# Default: http://localhost:6767
POCKETZ_SERVER_URL=http://localhost:6767

# Reconnection delay in milliseconds
# Default: 5000 (5 seconds)
RECONNECT_DELAY=5000

# Download timeout in milliseconds
# How long to wait after triggering Pocketz before considering job complete
# Default: 15000 (15 seconds)
DOWNLOAD_TIMEOUT=15000
